# Local development defaults. In Netlify, set these in Site configuration > Environment variables.
PORT=3000
BASE_URL=http://localhost:3000
JWT_SECRET=change_me_long_random_string

# For Netlify production, use your deployed site URL:
# BASE_URL=https://YOUR-SITE.netlify.app

# Discord OAuth / Dark Bot dashboard
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
# DISCORD_REDIRECT_URI=https://YOUR-SITE.netlify.app/auth/discord/callback
DISCORD_BOT_INVITE=https://discord.com/oauth2/authorize?client_id=963487472300482560

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# GOOGLE_REDIRECT_URI=https://YOUR-SITE.netlify.app/auth/google/callback

# Steam OpenID login
STEAM_API_KEY=your_steam_web_api_key
STEAM_RETURN_URL=http://localhost:3000/auth/steam/callback
STEAM_REALM=http://localhost:3000
# STEAM_RETURN_URL=https://YOUR-SITE.netlify.app/auth/steam/callback
# STEAM_REALM=https://YOUR-SITE.netlify.app

# Public support server invite used by About/Feedback buttons
SUPPORT_INVITE_URL=https://discord.gg/bJ8dqwSCuU

# Optional live bot health endpoint. If set, /api/portal-status probes it with a short timeout.
DISCORD_BOT_STATUS_URL=
STATUS_CHECK_TIMEOUT_MS=800

# On production, use real OAuth credentials. Local fallback is only for localhost testing.
ENABLE_LOCAL_PROVIDER_FALLBACK=true
FORCE_REAL_OAUTH=false

# Live guild dashboard sync timeout
GUILD_DASHBOARD_TIMEOUT_MS=9000

# Optional Netlify/Lambda SQLite path. Defaults to /tmp/dark-portal-dg.sqlite3 in functions.
DATABASE_PATH=
