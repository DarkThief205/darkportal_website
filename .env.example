PORT=3000
BASE_URL=http://localhost:3000
JWT_SECRET=change_me_long_random_string


# Discord OAuth / Dark Bot dashboard
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_BOT_INVITE=https://discord.com/oauth2/authorize?client_id=963487472300482560&permissions=8&scope=bot%20applications.commands

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Steam OpenID login
# Steam login itself uses OpenID and does not need a client secret.
# STEAM_API_KEY is optional, but recommended for reading persona name/avatar.
STEAM_API_KEY=your_steam_web_api_key
STEAM_RETURN_URL=http://localhost:3000/auth/steam/callback
STEAM_REALM=http://localhost:3000

# Portal status badges: online, partial, critical, offline

# Public support server invite used by About/Feedback buttons
SUPPORT_INVITE_URL=https://discord.gg/bJ8dqwSCuU

# Optional live bot health endpoint. If set, /api/portal-status probes it with a short timeout.
# Example when the bot exposes a local status endpoint: http://127.0.0.1:3001/status
DISCORD_BOT_STATUS_URL=http://127.0.0.1:3001/status
STATUS_CHECK_TIMEOUT_MS=800

# Local fallback lets provider buttons create a test account on localhost when real OAuth credentials are not configured.
ENABLE_LOCAL_PROVIDER_FALLBACK=true

# On localhost, provider buttons create a local Dark Portal account unless this is true.
FORCE_REAL_OAUTH=false

# Live guild dashboard sync timeout
GUILD_DASHBOARD_TIMEOUT_MS=9000
